APP_NAME=Live Trading Control Plane API
ENVIRONMENT=production
API_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://control_user:CHANGE_ME@127.0.0.1:5432/control_plane
DATABASE_ECHO=false
INGEST_API_KEY=CHANGE_ME_INGEST_KEY
ACTION_EXECUTOR_ENABLED=false
ACTION_EXECUTOR_RUNNER_KEY=ec2-a
ACTION_EXECUTOR_POLL_MS=1000
ACTION_EXECUTOR_TIMEOUT_SECS=120
ACTION_EXECUTOR_MAX_OUTPUT_CHARS=4000
# JSON string: {"btc_5m_main":{"start":"sudo systemctl start btc_5m_main","stop":"sudo systemctl stop btc_5m_main"}}
ACTION_COMMAND_MAP_JSON=
