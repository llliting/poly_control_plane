APP_NAME=Live Trading Control Plane API
ENVIRONMENT=production
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Postgres / SQLAlchemy URL
DATABASE_URL=postgresql+psycopg://control_user:CHANGE_ME@127.0.0.1:5432/control_plane
DATABASE_ECHO=false

# Shared with runner ingest clients
INGEST_API_KEY=CHANGE_ME_INGEST_KEY

# Local action executor for the services hosted on this EC2
ACTION_EXECUTOR_ENABLED=true
ACTION_EXECUTOR_RUNNER_KEY=ec2-a
ACTION_EXECUTOR_POLL_MS=1000
ACTION_EXECUTOR_TIMEOUT_SECS=1800
ACTION_EXECUTOR_MAX_OUTPUT_CHARS=4000

# Keep this as a single quoted line. Only include services that live on this EC2.
ACTION_COMMAND_MAP_JSON='{"btc_5m_main":{"build":"/home/ubuntu/5min-journey/rust/md-gateway/scripts/control_plane_action.sh build","start":"/home/ubuntu/5min-journey/rust/md-gateway/scripts/control_plane_action.sh start","stop":"/home/ubuntu/5min-journey/rust/md-gateway/scripts/control_plane_action.sh stop"}}'

# Optional: enrich /overview with current Polymarket wallet value / positions / trade activity
POLYMARKET_DATA_HOST=https://data-api.polymarket.com
POLYMARKET_OVERVIEW_WALLET=
